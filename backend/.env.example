# =============================================================================
# Stromteilung backend — canonical environment variables.
# Copy to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# App
APP_ENV=development                  # development | staging | production
APP_DEBUG=true
APP_NAME=stromteilung-backend
APP_SECRET_KEY=                      # 32+ chars, used to sign JWTs (openssl rand -hex 32)
APP_CORS_ORIGINS=http://localhost:5173

# Database
# Format: postgresql+asyncpg://<user>:<pass>@<host>:<port>/<dbname>
DATABASE_URL=
DATABASE_SSL=require                 # disable | prefer | require | verify-ca | verify-full
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_ECHO=false                  # set true to log every SQL statement (dev only)

# Auth
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900           # 15 minutes
JWT_REFRESH_TTL_SECONDS=2592000      # 30 days

# Logging
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_JSON=true                        # true in prod, false locally for readability
